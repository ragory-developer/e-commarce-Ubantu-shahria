model CheckoutSession {
  id String @id @default(cuid())

  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id])
  sessionId  String?   @map("session_id")

  // Immutable cart snapshot at checkout moment
  cartSnapshot Json @map("cart_snapshot") @db.JsonB

  addressId       String? @map("address_id")
  addressSnapshot Json    @map("address_snapshot") @db.JsonB

  deliveryZoneId String? @map("delivery_zone_id")
  courierId      String? @map("courier_id")
  shippingCost   Decimal @default(0) @map("shipping_cost") @db.Decimal(18, 4)

  couponId            String?             @map("coupon_id")
  couponCode          String?             @map("coupon_code") @db.VarChar(50)
  couponDiscountType  CouponDiscountType? @map("coupon_discount_type")
  couponDiscountValue Decimal?            @map("coupon_discount_value") @db.Decimal(18, 4)

  walletAmountUsed Decimal @default(0) @map("wallet_amount_used") @db.Decimal(18, 4)

  subTotal Decimal @map("sub_total") @db.Decimal(18, 4)
  discount Decimal @default(0) @db.Decimal(18, 4)
  total    Decimal @db.Decimal(18, 4)

  paymentMethod PaymentMethod @map("payment_method")

  // bKash paymentID / SSLCommerz sessionkey
  gatewayRef      String? @map("gateway_ref") @db.VarChar(255)
  gatewayResponse Json?   @map("gateway_response") @db.JsonB

  status    CheckoutStatus @default(PENDING)
  expiresAt DateTime       @map("expires_at")

  orderId String? @unique @map("order_id")

  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@index([sessionId])
  @@index([gatewayRef])
  @@index([status])
  @@index([expiresAt])
  @@index([orderId])
  @@map("checkout_sessions")
}
