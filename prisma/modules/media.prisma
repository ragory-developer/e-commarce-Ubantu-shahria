model Media {
  id String @id @default(cuid())

  filename     String @db.VarChar(191)
  originalName String @map("original_name") @db.VarChar(191)
  mimeType     String @map("mime_type") @db.VarChar(100)
  size         Int
  extension    String @db.VarChar(20)

  storageDriver String @map("storage_driver") @db.VarChar(20)
  storagePath   String @map("storage_path") @db.VarChar(500)
  storageUrl    String @map("storage_url") @db.VarChar(500)

  variants Json? @db.JsonB

  width  Int?
  height Int?
  alt    String? @db.VarChar(191)

  referenceCount Int @default(0) @map("reference_count")

  entityMedia EntityMedia[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([storageDriver])
  @@index([mimeType])
  @@index([referenceCount])
  @@index([storageDriver, deletedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("media")
}
