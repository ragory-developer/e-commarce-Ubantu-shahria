model Coupon {
  id String @id @default(cuid())

  name          String             @db.VarChar(191)
  code          String             @unique @db.VarChar(50)
  description   String?            @db.VarChar(500)
  discountType  CouponDiscountType @default(PERCENT) @map("discount_type")
  discountValue Decimal            @map("discount_value") @db.Decimal(12, 2)

  freeShipping Boolean @default(false) @map("free_shipping")

  minOrderValue Decimal? @map("min_order_value") @db.Decimal(12, 2)
  maxOrderValue Decimal? @map("max_order_value") @db.Decimal(12, 2)

  usageLimit     Int? @map("usage_limit")
  userUsageLimit Int? @map("user_usage_limit")
  used           Int  @default(0)

  validFrom DateTime @map("valid_from")
  validTo   DateTime @map("valid_to")

  applicableToAll Boolean @default(true) @map("applicable_to_all")

  isActive     Boolean @default(true) @map("is_active")
  translations Json?   @db.JsonB

  products   CouponProduct[]
  categories CouponCategory[]
  usages     CouponUsage[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([code])
  @@index([isActive])
  @@index([validFrom, validTo])
  @@index([deletedAt])
  @@map("coupons")
}
