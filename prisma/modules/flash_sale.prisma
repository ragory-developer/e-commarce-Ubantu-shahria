model FlashSale {
  id String @id @default(cuid())

  name          String          @db.VarChar(191)
  description   String?         @db.Text
  startTime     DateTime        @map("start_time")
  endTime       DateTime        @map("end_time")
  status        FlashSaleStatus @default(SCHEDULED)
  discountType  String          @db.VarChar(10)
  discountValue Decimal         @map("discount_value") @db.Decimal(12, 2)
  translations  Json?           @db.JsonB
  isActive      Boolean         @default(true) @map("is_active")

  products FlashSaleProduct[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, startTime, endTime])
  @@index([isActive, status])
  @@index([deletedAt])
  @@map("flash_sales")
}
