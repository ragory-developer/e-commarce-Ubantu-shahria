model Category {
  id String @id @default(cuid())

  parentId String?    @map("parent_id")
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  name        String  @db.VarChar(191)
  slug        String  @unique @db.VarChar(191)
  description String? @db.Text

  image       String? @db.VarChar(500)
  icon        String? @db.VarChar(191)
  bannerImage String? @map("banner_image") @db.VarChar(500)

  // Materialized path: "/electronics/phones/android"
  path    String? @db.VarChar(1000)
  pathIds String? @map("path_ids") @db.VarChar(1000)
  depth   Int     @default(0)

  isActive Boolean @default(true) @map("is_active")
  position Int     @default(0)

  metaTitle       String? @map("meta_title") @db.VarChar(255)
  metaDescription String? @map("meta_description") @db.VarChar(500)
  translations    Json?   @db.JsonB
  seo             Json?   @db.JsonB

  products ProductCategory[]
  coupons  CouponCategory[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([parentId])
  @@index([slug])
  @@index([path])
  @@index([pathIds])
  @@index([isActive])
  @@index([depth])
  @@index([isActive, depth, position])
  @@index([deletedAt])
  @@map("categories")
}
