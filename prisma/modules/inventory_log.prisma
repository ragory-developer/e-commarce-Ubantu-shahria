model InventoryLog {
  id String @id @default(cuid())

  productId        String          @map("product_id")
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId String?         @map("product_variant_id")
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  sku String? @db.VarChar(100)

  orderId            String? @map("order_id")
  flashSaleProductId String? @map("flash_sale_product_id")

  reason InventoryReason @default(MANUAL_ADJUSTMENT)

  qtyBefore Int @map("qty_before")
  qtyChange Int @map("qty_change") // positive=add, negative=deduct
  qtyAfter  Int @map("qty_after")

  reference String? @db.VarChar(100)
  notes     String? @db.VarChar(500)
  changedBy String? @map("changed_by")
  metadata  Json?   @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([productVariantId])
  @@index([orderId])
  @@index([flashSaleProductId])
  @@index([reason])
  @@index([productId, createdAt])
  @@index([createdAt])
  @@map("inventory_logs")
}
