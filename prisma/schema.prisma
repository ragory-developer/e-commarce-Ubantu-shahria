// ========================================
// MODULE:  FLASH_SALE.PRISMA
// ========================================

model FlashSale {
  id String @id @default(cuid())

  name          String          @db.VarChar(191)
  description   String?         @db.Text
  startTime     DateTime        @map("start_time")
  endTime       DateTime        @map("end_time")
  status        FlashSaleStatus @default(SCHEDULED)
  discountType  String          @db.VarChar(10)
  discountValue Decimal         @map("discount_value") @db.Decimal(12, 2)
  translations  Json?           @db.JsonB
  isActive      Boolean         @default(true) @map("is_active")

  products FlashSaleProduct[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([status, startTime, endTime])
  @@index([isActive, status])
  @@index([deletedAt])
  @@map("flash_sales")
}


// ========================================
// MODULE:  FLASH_SALE_PRODUCT.PRISMA
// ========================================

model FlashSaleProduct {
  id String @id @default(cuid())

  flashSaleId      String    @map("flash_sale_id")
  flashSale        FlashSale @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  productId        String    @map("product_id")
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId String?   @map("product_variant_id")

  price    Decimal @db.Decimal(18, 4)
  qty      Int
  sold     Int     @default(0)
  reserved Int     @default(0)
  position Int     @default(0)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@unique([flashSaleId, productId, productVariantId])
  @@index([flashSaleId])
  @@index([productId])
  @@index([productVariantId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("flash_sale_products")
}


// ========================================
// MODULE:  INVENTORY_LOG.PRISMA
// ========================================

model InventoryLog {
  id String @id @default(cuid())

  productId        String          @map("product_id")
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId String?         @map("product_variant_id")
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)

  sku String? @db.VarChar(100)

  orderId            String? @map("order_id")
  flashSaleProductId String? @map("flash_sale_product_id")

  reason InventoryReason @default(MANUAL_ADJUSTMENT)

  qtyBefore Int @map("qty_before")
  qtyChange Int @map("qty_change") // positive=add, negative=deduct
  qtyAfter  Int @map("qty_after")

  reference String? @db.VarChar(100)
  notes     String? @db.VarChar(500)
  changedBy String? @map("changed_by")
  metadata  Json?   @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([productVariantId])
  @@index([orderId])
  @@index([flashSaleProductId])
  @@index([reason])
  @@index([productId, createdAt])
  @@index([createdAt])
  @@map("inventory_logs")
}


