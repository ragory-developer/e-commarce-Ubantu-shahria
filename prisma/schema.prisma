// ========================================

model Wallet {
  id String @id @default(cuid())

  customerId String   @unique @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  // Cached balance — recompute from transactions for integrity check
  balance  Decimal @default(0) @db.Decimal(18, 4)
  currency String  @default("BDT") @db.VarChar(10)

  isActive Boolean @default(true) @map("is_active")

  transactions WalletTransaction[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([customerId])
  @@map("wallets")
}


// ========================================
// MODULE:  WALLET_TRANSACTION.PRISMA
// ========================================

model WalletTransaction {
  id String @id @default(cuid())

  walletId String @map("wallet_id")
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type WalletTransactionType

  amount  Decimal @db.Decimal(18, 4) // positive=credit, negative=debit
  balance Decimal @db.Decimal(18, 4) // running balance AFTER this transaction

  orderId     String? @map("order_id")
  returnId    String? @map("return_id")
  referenceId String? @map("reference_id")

  description String?   @db.VarChar(255)
  expiresAt   DateTime? @map("expires_at")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([walletId])
  @@index([type])
  @@index([orderId])
  @@index([walletId, createdAt])
  @@map("wallet_transactions")
}
