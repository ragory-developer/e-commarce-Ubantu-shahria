// ========================================
// MODULE:  ORDER.PRISMA
// ========================================

model Order {
  id          String @id @default(cuid())
  orderNumber Int    @unique @default(autoincrement()) @map("order_number")

  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Customer snapshot — immutable
  customerEmail     String @map("customer_email") @db.VarChar(191)
  customerPhone     String @map("customer_phone") @db.VarChar(50)
  customerFirstName String @map("customer_first_name") @db.VarChar(191)
  customerLastName  String @map("customer_last_name") @db.VarChar(191)

  // Address snapshot — immutable JSON
  shippingAddress Json @map("shipping_address") @db.JsonB
  billingAddress  Json @map("billing_address") @db.JsonB

  deliveryZoneId String?       @map("delivery_zone_id")
  deliveryZone   DeliveryZone? @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)
  courierId      String?       @map("courier_id")
  courierName    String?       @map("courier_name") @db.VarChar(100)
  trackingNumber String?       @map("tracking_number")

  subTotal     Decimal @map("sub_total") @db.Decimal(18, 4)
  shippingCost Decimal @default(0) @map("shipping_cost") @db.Decimal(18, 4)
  discount     Decimal @default(0) @db.Decimal(18, 4)
  taxTotal     Decimal @default(0) @map("tax_total") @db.Decimal(18, 4)
  total        Decimal @db.Decimal(18, 4)

  paymentMethod PaymentMethod @map("payment_method")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")

  couponId            String?             @map("coupon_id")
  couponCode          String?             @map("coupon_code") @db.VarChar(50)
  couponDiscountType  CouponDiscountType? @map("coupon_discount_type")
  couponDiscountValue Decimal?            @map("coupon_discount_value") @db.Decimal(18, 4)

  walletAmountUsed Decimal @default(0) @map("wallet_amount_used") @db.Decimal(18, 4)

  currency     String  @default("BDT") @db.VarChar(10)
  currencyRate Decimal @default(1) @map("currency_rate") @db.Decimal(18, 4)

  status OrderStatus @default(PENDING)

  notes     Json?   @db.JsonB
  locale    String  @default("bn-BD") @db.VarChar(10)
  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(500)

  confirmedAt DateTime? @map("confirmed_at")
  shippedAt   DateTime? @map("shipped_at")
  deliveredAt DateTime? @map("delivered_at")
  canceledAt  DateTime? @map("canceled_at")
  refundedAt  DateTime? @map("refunded_at")

  products      OrderProduct[]
  taxes         OrderTax[]
  statusHistory OrderStatusHistory[]
  packages      OrderPackage[]
  transaction   Transaction?
  returns       OrderReturn[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by")
  updatedBy String?   @map("updated_by")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([orderNumber])
  @@index([paymentMethod])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("orders")
}


// ========================================
// MODULE:  ORDER_PACKAGE.PRISMA
// ========================================

model OrderPackage {
  id String @id @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  courierId String?  @map("courier_id")
  courier   Courier? @relation(fields: [courierId], references: [id])

  riderId String?        @map("rider_id")
  rider   DeliveryRider? @relation(fields: [riderId], references: [id], onDelete: SetNull)

  status         PackageStatus @default(CREATED)
  trackingNumber String?       @map("tracking_number") @db.VarChar(191)

  // [{ orderProductId, productName, qty, weight }]
  items Json @db.JsonB

  packedAt    DateTime? @map("packed_at")
  packedBy    String?   @map("packed_by")
  assignedAt  DateTime? @map("assigned_at")
  assignedBy  String?   @map("assigned_by")
  pickedUpAt  DateTime? @map("picked_up_at")
  deliveredAt DateTime? @map("delivered_at")
  failedAt    DateTime? @map("failed_at")
  returnedAt  DateTime? @map("returned_at")

  // { deliveryPhoto, signature, receivedBy, failureReason, attempts }
  deliveryDetails Json? @map("delivery_details") @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([orderId])
  @@index([riderId])
  @@index([courierId])
  @@index([status])
  @@index([trackingNumber])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("order_packages")
}


// ========================================
// MODULE:  ORDER_PRODUCT.PRISMA
// ========================================

model OrderProduct {
  id String @id @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])

  productVariantId String?         @map("product_variant_id")
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  // Snapshot at order time
  productName  String  @map("product_name") @db.VarChar(191)
  productSku   String? @map("product_sku") @db.VarChar(100)
  productSlug  String  @map("product_slug") @db.VarChar(191)
  productImage Json?   @map("product_image") @db.JsonB

  unitPrice Decimal @map("unit_price") @db.Decimal(18, 4)
  qty       Int
  lineTotal Decimal @map("line_total") @db.Decimal(18, 4)

  // Selected variations snapshot: [{ name:"Color", value:"Red", type:"COLOR" }]
  variationsSnapshot Json? @map("variations_snapshot") @db.JsonB

  @@index([orderId])
  @@index([productId])
  @@map("order_products")
}


// ========================================
// MODULE:  ORDER_RETURN.PRISMA
// ========================================

model OrderReturn {
  id String @id @default(cuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  customerId String?   @map("customer_id")
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // [{ orderProductId, productName, qty, unitPrice, reason }]
  items Json @db.JsonB

  reason       ReturnReason
  reasonDetail String?      @map("reason_detail") @db.VarChar(500)

  // Evidence photos from customer
  evidenceImages Json? @map("evidence_images") @db.JsonB

  status ReturnStatus @default(REQUESTED)

  reviewedBy String?   @map("reviewed_by")
  reviewedAt DateTime? @map("reviewed_at")
  reviewNote String?   @map("review_note") @db.VarChar(500)

  // Separate package for return pickup by rider
  pickupPackageId String? @map("pickup_package_id")

  inspectedBy    String?   @map("inspected_by")
  inspectedAt    DateTime? @map("inspected_at")
  inspectionNote String?   @map("inspection_note") @db.VarChar(500)

  refundId String? @map("refund_id")

  walletCreditAmount Decimal? @map("wallet_credit_amount") @db.Decimal(18, 4)
  refundMethod       String?  @map("refund_method") @db.VarChar(20) // GATEWAY | WALLET

  completedAt DateTime? @map("completed_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by")

  @@index([orderId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("order_returns")
}


// ========================================
// MODULE:  ORDER_STATUS.HISTORY.PRISMA
